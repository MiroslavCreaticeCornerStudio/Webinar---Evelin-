---
const castingLinks = [
  ["Какво представлява", "Коя е Ралица"],
  ["Кого търсим", "„Борба до ключ”"],
];
---

<footer class="footer">
  <div class="footer__top container container--padded">
    <div class="footer__brand">
      <a class="footer__logo" href="#top" aria-label="Home2U — начало">
        <img src="/assets/images/footer-logo-icon.svg" alt="" class="footer__logo-icon" />
        <img src="/assets/images/footer-logo-text.svg" alt="Home2U" class="footer__logo-text" />
      </a>
      <div class="footer__signup">
        <span class="footer__signup-script">Запиши се СЕГА</span>
        <img src="/assets/images/footer-arrow.svg" alt="" class="footer__signup-arrow" aria-hidden="true" />
      </div>
      <span class="footer__deco footer__deco--clap" aria-hidden="true">
        <img src="/assets/images/footer-deco-1.png" alt="" />
      </span>
    </div>

    <div class="footer__cols">
      <div class="footer__col">
        <h2 class="footer__col-title">Кастинг</h2>
        <div class="footer__links">
          {castingLinks.map((group) => (
            <div class="footer__link-group">
              {group.map((label) => <a href="#">{label}</a>)}
            </div>
          ))}
        </div>
      </div>

      <div class="footer__col footer__col--contact">
        <span class="footer__deco footer__deco--mic" aria-hidden="true">
          <img src="/assets/images/footer-deco-2.png" alt="" />
        </span>
        <h2 class="footer__col-title">Контакти</h2>
        <div class="footer__contacts">
          <a class="footer__contact" href="tel:+35988788333222">
            <img src="/assets/images/footer-icon-phone.svg" alt="" />
            +359 887 88333222
          </a>
          <a class="footer__contact" href="mailto:info@home2u.com">
            <img src="/assets/images/footer-icon-email.svg" alt="" />
            info@home2u.com
          </a>
        </div>
      </div>
    </div>
  </div>

  <div class="footer__bar">
    <div class="footer__bar-inner container container--padded">
      <div class="footer__legal">
        <a href="#">Защита на личните данни</a>
        <span aria-hidden="true">|</span>
        <a href="#">Информация по ЗЗЛПСПООИН</a>
      </div>
      <span class="footer__copy">“Home2U Real Estate”, 2025</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    width: 100%;
    background-color: var(--color-bg-white);
  }

  .footer__top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 2em;
    padding-top: 3.5em; /* ~57-78px */
    padding-bottom: 3.5em;
  }

  /* Brand */
  .footer__brand {
    position: relative;
    flex-shrink: 0;
  }
  .footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 1.3em;
  }
  .footer__logo-icon {
    width: 4.3em; /* ~68.8px square */
    height: 4.3em;
  }
  .footer__logo-text {
    width: 17.74em; /* ~284px (4.17:1) */
    height: 4.25em;
  }
  .footer__signup {
    position: relative;
    display: inline-flex;
    align-items: flex-start;
    margin-top: 0.5em;
    margin-left: 6em;
  }
  .footer__signup-script {
    font-family: var(--font-script);
    font-size: 2.7em; /* ~43px */
    font-weight: 700;
    line-height: 1;
    color: var(--color-accent);
  }
  .footer__signup-arrow {
    width: 3em;
    height: 4.84em; /* 0.62:1 arrow */
    margin-left: 0.2em;
  }
  .footer__deco {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4em; /* 64px */
    height: 4em;
    border: 1px solid #ffffff;
    border-radius: 0.347em; /* 5.559px */
    background-image: linear-gradient(
      -63deg,
      rgba(231, 241, 248, 0.7) 0%,
      rgba(248, 234, 237, 0.7) 100%
    );
    box-shadow: 0px 6.575px 13.151px 0px rgba(169, 8, 49, 0.19);
    overflow: hidden;
  }
  .footer__deco img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .footer__deco--clap {
    position: absolute;
    top: 0;
    left: 25em;
  }

  /* Columns */
  .footer__cols {
    display: flex;
    gap: 3.3125em; /* 53px */
    align-items: flex-start;
  }
  .footer__col {
    position: relative;
  }
  .footer__col-title {
    font-family: var(--font-body);
    font-size: 1.125em; /* 18px */
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-primary);
    padding-bottom: 0.5em;
    border-bottom: 1px solid #c6c6c6;
  }
  .footer__col--contact .footer__col-title {
    width: 14.4375em; /* 231px */
  }
  .footer__col:not(.footer__col--contact) .footer__col-title {
    width: 21.0625em; /* 337px */
  }

  .footer__links {
    display: flex;
    gap: 3em; /* 48px */
    margin-top: 1.5em;
  }
  .footer__link-group {
    display: flex;
    flex-direction: column;
    gap: 0.75em; /* 12px */
  }
  .footer__link-group a {
    font-family: var(--font-body);
    font-size: 0.875em; /* 14px */
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-text-primary);
    white-space: nowrap;
  }

  .footer__contacts {
    display: flex;
    flex-direction: column;
    gap: 1.4em; /* 22.45px */
    margin-top: 1.5em;
  }
  .footer__contact {
    display: inline-flex;
    align-items: center;
    gap: 1.05em; /* 16.8px */
    font-family: var(--font-body);
    font-size: 1.09em; /* 17.481px */
    font-weight: 300;
    line-height: 1.3;
    color: var(--color-text-primary);
    white-space: nowrap;
  }
  .footer__contact img {
    width: 1.09em; /* ~17.5px */
    height: 1.09em;
  }
  .footer__deco--mic {
    position: absolute;
    top: -2em;
    right: 0;
  }

  /* Bottom bar */
  .footer__bar {
    width: 100%;
    background-color: var(--color-accent);
  }
  .footer__bar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1em;
    min-height: 2.75em; /* 44px */
    padding-block: 0.5em;
  }
  .footer__legal {
    display: flex;
    align-items: center;
    gap: 1em; /* 16px */
  }
  .footer__legal a {
    font-family: var(--font-body);
    font-size: 0.875em; /* 14px */
    font-weight: 400;
    color: var(--color-text-white);
    text-decoration: underline;
  }
  .footer__legal span {
    color: var(--color-text-white);
  }
  .footer__copy {
    font-family: var(--font-body);
    font-size: 0.875em; /* 14px */
    color: var(--color-text-white);
    white-space: nowrap;
  }

  @media (max-width: 991px) {
    .footer__top {
      flex-direction: column;
      gap: 3em;
    }
    .footer__deco--clap {
      display: none;
    }
    .footer__cols {
      flex-direction: column;
      gap: 2.5em;
      width: 100%;
    }
    .footer__col {
      width: 100%;
    }
    .footer__col--contact .footer__col-title,
    .footer__col:not(.footer__col--contact) .footer__col-title {
      width: 100%;
    }
    .footer__links {
      flex-wrap: wrap;
      gap: 1.5em 3em;
    }
    .footer__bar-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75em;
      padding-block: 1em;
    }
    .footer__legal {
      flex-wrap: wrap;
    }
  }
</style>
