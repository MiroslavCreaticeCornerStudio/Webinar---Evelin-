---
const criteria = [
  "Търсиш възможност за дългосрочна кариера, а не просто кратък момент на внимание.",
  "Можеш да приемаш обратна връзка така, че да се учиш от нея.",
  "Искаш да градиш дългосрочен успех в имотния бизнес.",
  "Имаш чувство за хумор, но знаеш кога е време за сериозна работа.",
  "Не се притесняваш от камери и динамична среда.",
  "Комуникативен си и умееш да печелиш доверие.",
];
---

<section class="lookfor">
  <div class="lookfor__inner container container--padded">
    <div class="lookfor__head">
      <div class="lookfor__head-top">
        <img src="/assets/images/lookfor-line.svg" alt="" class="lookfor__line" aria-hidden="true" />
        <h2 class="lookfor__title">Търсим човек с хъс, характер и присъствие</h2>
      </div>
      <p class="lookfor__subtitle">Не е нужно да имаш предишен опит като брокер. Нужно е да имаш желание да се учиш, да действаш смело и да не се отказваш при първата трудност.</p>
    </div>

    <div class="lookfor__body">
      <div class="lookfor__main">
        <ul class="lookfor__cards">
          {criteria.map((text) => (
            <li class="lookfor__card">
              <span class="lookfor__icon">
                <img src="/assets/images/lookfor-icon-check.svg" alt="" width="18" height="18" loading="lazy" />
              </span>
              <p class="lookfor__card-text">{text}</p>
            </li>
          ))}
        </ul>

        <div class="lookfor__cta">
          <p class="lookfor__cta-title">Имаш състезателен дух?</p>
          <a href="#kandidatstvai" class="lookfor__cta-link">
            Запиши се сега
            <img src="/assets/images/lookfor-button-arrow.svg" alt="" width="20" height="11" />
          </a>
          <span class="lookfor__cta-mark" aria-hidden="true">?</span>
        </div>
      </div>

      <div class="lookfor__image">
        <img src="/assets/images/lookfor-image.jpg" alt="Ралица Ценова в режисьорски стол" width="538" height="754" loading="lazy" />
      </div>
    </div>
  </div>
</section>

<style>
  .lookfor {
    width: 100%;
    background-color: var(--color-bg-white);
    padding-block: 5em; /* 80px */
  }
  .lookfor__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 3.5em; /* 56px */
  }

  .lookfor__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75em; /* 12px */
    width: 42.75em; /* 684px */
    max-width: 100%;
  }
  .lookfor__head-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25em; /* 20px */
  }
  .lookfor__line {
    width: 2.5em;
    height: 2px;
  }
  .lookfor__title {
    font-family: var(--font-heading);
    font-size: 2.625em; /* 42px */
    font-weight: 500;
    line-height: 1.19;
    color: #000000;
    text-align: center;
  }
  .lookfor__subtitle {
    font-family: var(--font-body);
    font-size: 1.125em; /* 18px */
    font-weight: 400;
    line-height: 1.5;
    color: #4f4f4f;
    text-align: center;
  }

  .lookfor__body {
    display: flex;
    gap: 1.5em; /* 24px */
    align-items: stretch;
    width: 100%;
  }

  .lookfor__main {
    display: flex;
    flex-direction: column;
    gap: 1em; /* 16px */
    width: 44.875em; /* 718px */
    flex-shrink: 0;
  }

  .lookfor__cards {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1em; /* 16px */
  }
  .lookfor__card {
    display: flex;
    flex-direction: column;
    gap: 1em; /* 16px */
    padding: 1.5em; /* 24px */
    border: 1px solid var(--color-bg-white);
    border-radius: 1em; /* 16px */
    background-image: linear-gradient(
      -47deg,
      rgba(231, 241, 248, 0.7) 0%,
      rgba(248, 234, 237, 0.7) 100%
    );
    backdrop-filter: blur(4px);
  }
  .lookfor__icon {
    display: inline-flex;
    width: 1.125em; /* 18px */
    height: 1.125em;
  }
  .lookfor__icon img {
    width: 100%;
    height: 100%;
  }
  .lookfor__card-text {
    font-family: var(--font-heading);
    font-size: 1.125em; /* 18px */
    font-weight: 500;
    line-height: 1.5;
    color: #4f4f4f;
  }

  .lookfor__cta {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 8.5em; /* 136px */
    padding: 1.5em; /* 24px */
    border-radius: 1em; /* 16px */
    background-color: var(--color-accent);
    box-shadow: 0px 5px 30px 0px rgba(169, 8, 49, 0.4);
    overflow: hidden;
  }
  .lookfor__cta-title {
    font-family: var(--font-heading);
    font-size: 1.375em; /* 22px */
    font-weight: 500;
    line-height: 1.227;
    color: var(--color-text-white);
    position: relative;
    z-index: 1;
  }
  .lookfor__cta-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75em; /* 12px */
    font-family: var(--font-heading);
    font-size: 1.125em; /* 18px */
    font-weight: 500;
    line-height: 1.4;
    color: var(--color-text-white);
    position: relative;
    z-index: 1;
  }
  .lookfor__cta-link img {
    width: 1.25em; /* 20px */
    height: 0.6875em; /* 11px (20:11) */
  }
  .lookfor__cta-mark {
    position: absolute;
    top: -0.45em;
    right: 0.4em;
    font-family: var(--font-heading);
    font-weight: 800;
    font-size: 15.4em; /* ~246px */
    line-height: 1;
    color: #ba143e;
    transform: rotate(-24deg);
    z-index: 0;
    pointer-events: none;
  }

  .lookfor__image {
    flex: 1;
    min-width: 0;
    border-radius: 1.5em; /* 24px */
    overflow: hidden;
    background-color: var(--color-accent);
  }
  .lookfor__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 991px) {
    .lookfor__title {
      font-size: 2.25em;
    }
    .lookfor__main {
      width: 30em;
    }
    .lookfor__card-text {
      font-size: 1em;
    }
  }

  @media (max-width: 767px) {
    .lookfor__body {
      flex-direction: column;
    }
    .lookfor__main {
      width: 100%;
    }
    .lookfor__image {
      width: 100%;
      min-height: 25em;
    }
  }

  @media (max-width: 479px) {
    .lookfor__cards {
      grid-template-columns: 1fr;
    }
  }
</style>
